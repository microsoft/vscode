{
  "index_patterns": ["tscode-telemetry-*"],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "index.refresh_interval": "5s",
      "analysis": {
        "analyzer": {
          "path_analyzer": {
            "tokenizer": "path_tokenizer"
          }
        },
        "tokenizer": {
          "path_tokenizer": {
            "type": "path_hierarchy",
            "delimiter": "/"
          }
        }
      }
    },
    "mappings": {
      "properties": {
        "@timestamp":                  { "type": "date" },
        "event_name":                  { "type": "keyword" },
        "event_type":                  { "type": "keyword" },
        "machine_id":                  { "type": "keyword" },
        "session_id":                  { "type": "keyword" },
        "device_id":                   { "type": "keyword" },
        "vscode_version":              { "type": "keyword" },
        "commit_hash":                 { "type": "keyword" },
        "platform":                    { "type": "keyword" },
        "node_arch":                   { "type": "keyword" },
        "instrumentation_key":         { "type": "keyword" },
        "theme":                       { "type": "keyword" },
        "ui_language":                 { "type": "keyword" },
        "extension_id":                { "type": "keyword" },
        "extension_name":              { "type": "keyword" },
        "activation_time_ms":          { "type": "float" },
        "time_since_session_start":    { "type": "long" },
        "event_sequence":              { "type": "long" },
        "tags":                        { "type": "keyword" },
        "error_message": {
          "type": "text",
          "fields": {
            "keyword": { "type": "keyword", "ignore_above": 256 }
          }
        },
        "message":                     { "type": "text" },
        "telemetry": {
          "type": "object",
          "enabled": false
        }
      }
    }
  },
  "priority": 100
}
