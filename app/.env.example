# AI Studio Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# GitHub Personal Access Token (required for publishing releases)
# Generate at: https://github.com/settings/tokens/new
# Required permissions: repo, workflow
GH_TOKEN=

# OpenAI-compatible API key (required for AI features)
OPENAI_API_KEY=

# Optional: Custom AI API base URL (for alternative providers like Ollama, DeepSeek)
# AI_BASE_URL=https://api.openai.com/v1

# Optional: Default AI model
# AI_MODEL=gpt-4o-mini
