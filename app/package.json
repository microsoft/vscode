{
  "name": "ai-studio-ide",
  "version": "1.0.0",
  "description": "Lightweight AI-powered desktop IDE",
  "author": "AI Studio",
  "license": "MIT",
  "private": true,
  "main": "dist/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:frontend": "cd frontend && vite --port 5173",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build": "npm run build:frontend && npm run build:electron",
    "build:frontend": "cd frontend && vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "publish": "npm run build && electron-builder --publish always",
    "publish:win": "npm run build && electron-builder --win --publish always",
    "publish:linux": "npm run build && electron-builder --linux --publish always",
    "release": "npm run build && electron-builder --publish always",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern dist --ignore-pattern node_modules",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist out",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "electron-updater": "^6.3.9",
    "express": "^4.21.1",
    "node-pty": "^1.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "eslint": "^8.57.0",
    "lucide-react": "^0.460.0",
    "monaco-editor": "^0.52.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.1"
  }
}
