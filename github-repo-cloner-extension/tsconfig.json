{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "baseUrl": ".",
    "paths": {
      "vscode": [
        "../src/vscode-dts/vscode"
      ]
    },
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": [
    "src"
  ]
}
