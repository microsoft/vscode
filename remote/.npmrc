disturl="https://nodejs.org/dist"
target="24.15.0"
ms_build_id="438265"
runtime="node"
build_from_source="true"
timeout=180000
min-release-age="1"

# pnpm settings (migrated from npm). remote/ is installed as a standalone,
# Node-runtime project (separate from the Electron-runtime workspace) so native
# modules are built against Node headers for the remote server.
node-linker=hoisted
strict-peer-dependencies=false
auto-install-peers=false
