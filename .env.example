# Son of Anton — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# FalkorDB
FALKORDB_HOST=falkordb
FALKORDB_PORT=6379

# Qdrant
QDRANT_HOST=qdrant
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334

# Indexer
PROJECT_PATH=/workspace
LANGUAGES=typescript,python,rust,csharp,cpp

# MCP Gateway
MCP_PORT=3100

# LLM
ANTHROPIC_API_KEY=your-key-here
