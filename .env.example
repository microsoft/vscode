# Son of Anton — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# FalkorDB
FALKORDB_HOST=falkordb
FALKORDB_PORT=6379

# Qdrant
QDRANT_HOST=qdrant
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334

# Indexer
PROJECT_PATH=/workspace
LANGUAGES=typescript,python,rust,csharp,cpp

# MCP Gateway (Code Graph)
MCP_PORT=3100

# MCP Database Server
DB_HOST=localhost
DB_PORT=5432
DB_NAME=son_of_anton
DB_USER=readonly
DB_PASSWORD=

# MCP Deployment & Tickets Servers
GITHUB_REPOSITORY=CodeHalwell/Son-Of-Anton
GITHUB_TOKEN=

# LLM
ANTHROPIC_API_KEY=your-key-here
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Model Router
MODEL_ROUTER_PORT=3200
MODEL_ROUTER_URL=http://model-router:3200

# Workspace Checkpoints
CHECKPOINT_PORT=3201

# Walkthrough Generator
WALKTHROUGH_PORT=3202
