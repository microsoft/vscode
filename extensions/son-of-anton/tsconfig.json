{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./out",
		"lib": [
			"ES2024",
			"DOM"
		],
		"skipLibCheck": true,
		"ignoreDeprecations": "6.0",
		"paths": {
			"son-of-anton-core": ["../../son-of-anton-core/dist/index.d.ts"],
			"son-of-anton-core/*": ["../../son-of-anton-core/dist/*.d.ts"]
		}
	},
	"include": [
		"src/**/*",
		"../../src/vscode-dts/vscode.d.ts",
		"../types/lib.textEncoder.d.ts"
	],
	"exclude": [
		"src/board/webview/**/*"
	]
}
