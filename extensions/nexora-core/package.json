{
  "name": "nexora-core",
  "displayName": "Nexora Core",
  "description": "Universal AI Orchestration System - Core Extension",
  "version": "1.0.0",
  "publisher": "nexora-team",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nexora-sidebar",
          "title": "Nexora AI",
          "icon": "media/nexora-icon.svg"
        }
      ]
    },
    "views": {
      "nexora-sidebar": [
        {
          "type": "webview",
          "id": "nexora.chatPanel",
          "name": "Nexora Chat"
        },
        {
          "id": "nexora.taskTree",
          "name": "Task Plan"
        },
        {
          "id": "nexora.platformBrowser",
          "name": "Platform Browser"
        }
      ]
    },
    "commands": [
      {
        "command": "nexora.openChat",
        "title": "Open Nexora Chat",
        "category": "Nexora"
      },
      {
        "command": "nexora.refreshPlatforms",
        "title": "Refresh Platforms",
        "category": "Nexora",
        "icon": "$(refresh)"
      },
      {
        "command": "nexora.checkBackend",
        "title": "Check Backend Connection",
        "category": "Nexora"
      },
      {
        "command": "nexora.decomposeRequest",
        "title": "Plan Tasks",
        "category": "Nexora",
        "icon": "$(list-tree)"
      },
      {
        "command": "nexora.clearTasks",
        "title": "Clear Task Plan",
        "category": "Nexora",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "nexora.refreshPlatforms",
          "when": "view == nexora.platformBrowser",
          "group": "navigation"
        },
        {
          "command": "nexora.decomposeRequest",
          "when": "view == nexora.taskTree",
          "group": "navigation"
        },
        {
          "command": "nexora.clearTasks",
          "when": "view == nexora.taskTree",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node scripts/copyWebviewAssets.js",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
