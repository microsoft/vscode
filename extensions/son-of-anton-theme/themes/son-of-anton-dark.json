	"tokenColors": [
		{
			"name": "Comments",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": { "foreground": "#546e7a", "fontStyle": "italic" }
		},
		{
			"name": "Keywords",
			"scope": ["keyword", "storage.type", "storage.modifier"],
			"settings": { "foreground": "#c792ea" }
		},
		{
			"name": "Control keywords",
			"scope": ["keyword.control", "keyword.control.import", "keyword.control.export", "keyword.control.from"],
			"settings": { "foreground": "#c792ea" }
		},
		{
			"name": "Functions",
			"scope": ["entity.name.function", "meta.function-call", "support.function"],
			"settings": { "foreground": "#82aaff" }
		},
		{
			"name": "Strings",
			"scope": ["string", "string.template", "punctuation.definition.string"],
			"settings": { "foreground": "#c3e88d" }
		},
		{
			"name": "Template expression",
			"scope": ["punctuation.definition.template-expression", "string.template punctuation"],
			"settings": { "foreground": "#89ddff" }
		},
		{
			"name": "Numbers",
			"scope": ["constant.numeric"],
			"settings": { "foreground": "#f78c6c" }
		},
		{
			"name": "Constants",
			"scope": ["constant.language", "variable.language"],
			"settings": { "foreground": "#f78c6c" }
		},
		{
			"name": "Types and interfaces",
			"scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
			"settings": { "foreground": "#ffcb6b" }
		},
		{
			"name": "Operators and punctuation",
			"scope": ["keyword.operator", "punctuation.accessor", "punctuation.separator"],
			"settings": { "foreground": "#89ddff" }
		},
		{
			"name": "Variables",
			"scope": ["variable", "variable.other", "variable.parameter"],
			"settings": { "foreground": "#e4e4e8" }
		},
		{
			"name": "Object properties",
			"scope": ["variable.other.property", "variable.other.object.property", "meta.object-literal.key"],
			"settings": { "foreground": "#82aaff" }
		},
		{
			"name": "HTML tags",
			"scope": ["entity.name.tag", "punctuation.definition.tag"],
			"settings": { "foreground": "#f07178" }
		},
		{
			"name": "HTML attributes",
			"scope": ["entity.other.attribute-name"],
			"settings": { "foreground": "#c792ea", "fontStyle": "italic" }
		},
		{
			"name": "JSX component tags",
			"scope": ["support.class.component"],
			"settings": { "foreground": "#ffcb6b" }
		},
		{
			"name": "Decorators",
			"scope": ["meta.decorator", "punctuation.decorator"],
			"settings": { "foreground": "#e8a634" }
		},
		{
			"name": "Regular expressions",
			"scope": ["string.regexp"],
			"settings": { "foreground": "#89ddff" }
		},
		{
			"name": "CSS properties",
			"scope": ["support.type.property-name.css"],
			"settings": { "foreground": "#82aaff" }
		},
		{
			"name": "CSS values",
			"scope": ["support.constant.property-value.css"],
			"settings": { "foreground": "#c3e88d" }
		},
		{
			"name": "CSS selectors",
			"scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
			"settings": { "foreground": "#ffcb6b" }
		},
		{
			"name": "Markdown headings",
			"scope": ["markup.heading", "entity.name.section.markdown"],
			"settings": { "foreground": "#e8a634", "fontStyle": "bold" }
		},
		{
			"name": "Markdown bold",
			"scope": ["markup.bold"],
			"settings": { "fontStyle": "bold" }
		},
		{
			"name": "Markdown italic",
			"scope": ["markup.italic"],
			"settings": { "fontStyle": "italic" }
		},
		{
			"name": "Markdown links",
			"scope": ["markup.underline.link"],
			"settings": { "foreground": "#60a5fa" }
		},
		{
			"name": "Markdown code",
			"scope": ["markup.inline.raw", "markup.fenced_code"],
			"settings": { "foreground": "#c3e88d" }
		},
		{
			"name": "JSON property names",
			"scope": ["support.type.property-name.json"],
			"settings": { "foreground": "#82aaff" }
		},
		{
			"name": "YAML keys",
			"scope": ["entity.name.tag.yaml"],
			"settings": { "foreground": "#82aaff" }
		},
		{
			"name": "Type parameters",
			"scope": ["meta.type.parameters", "punctuation.definition.typeparameters"],
			"settings": { "foreground": "#89ddff" }
		},
		{
			"name": "Interface keyword",
			"scope": ["keyword.other.type", "storage.type.interface", "storage.type.type"],
			"settings": { "foreground": "#c792ea" }
		},
		{
			"name": "Namespace",
			"scope": ["entity.name.namespace", "entity.name.module"],
			"settings": { "foreground": "#e4e4e8" }
		},
		{
			"name": "Enum members",
			"scope": ["variable.other.enummember"],
			"settings": { "foreground": "#f78c6c" }
		}
	],
	"semanticHighlighting": true,
	"semanticTokenColors": {
		"function": "#82aaff",
		"function.declaration": "#82aaff",
		"method": "#82aaff",
		"method.declaration": "#82aaff",
		"variable": "#e4e4e8",
		"variable.declaration": "#e4e4e8",
		"variable.readonly": "#e4e4e8",
		"parameter": "#e4e4e8",
		"property": "#82aaff",
		"property.declaration": "#82aaff",
		"type": "#ffcb6b",
		"class": "#ffcb6b",
		"interface": "#ffcb6b",
		"enum": "#ffcb6b",
		"enumMember": "#f78c6c",
		"namespace": "#e4e4e8",
		"typeParameter": "#ffcb6b",
		"decorator": "#e8a634"
	}
}
