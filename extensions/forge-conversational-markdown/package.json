{
	"name": "forge-conversational-markdown",
	"displayName": "%displayName%",
	"description": "%description%",
	"version": "1.0.0",
	"author": "Forge Contributors",
	"publisher": "vscode",
	"license": "MIT",
	"aiKey": "0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCustomEditor:forge.conversationalMarkdown",
		"onCommand:forgeMarkdown.openConversationalPreview"
	],
	"main": "./out/extension",
	"capabilities": {
		"virtualWorkspaces": false,
		"untrustedWorkspaces": {
			"supported": true
		}
	},
	"contributes": {
		"customEditors": [
			{
				"viewType": "forge.conversationalMarkdown",
				"displayName": "%customEditor.displayName%",
				"priority": "option",
				"selector": [
					{
						"filenamePattern": "*.md"
					}
				]
			}
		],
		"commands": [
			{
				"command": "forgeMarkdown.openConversationalPreview",
				"title": "%command.openConversationalPreview%",
				"category": "Forge"
			},
			{
				"command": "forgeMarkdown.showSource",
				"title": "%command.showSource%",
				"category": "Forge",
				"enablement": "activeCustomEditorId == 'forge.conversationalMarkdown'"
			},
			{
				"command": "forgeMarkdown.refreshPreview",
				"title": "%command.refreshPreview%",
				"category": "Forge",
				"enablement": "activeCustomEditorId == 'forge.conversationalMarkdown'"
			},
			{
				"command": "forgeMarkdown.speEngineer",
				"title": "%command.speEngineer%",
				"category": "Forge",
				"enablement": "activeCustomEditorId == 'forge.conversationalMarkdown'"
			},
			{
				"command": "forgeMarkdown.revealNextOpenThread",
				"title": "%command.revealNextOpenThread%",
				"category": "Forge",
				"enablement": "activeCustomEditorId == 'forge.conversationalMarkdown'"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "forgeMarkdown.showSource",
					"when": "activeCustomEditorId == 'forge.conversationalMarkdown'"
				},
				{
					"command": "forgeMarkdown.refreshPreview",
					"when": "activeCustomEditorId == 'forge.conversationalMarkdown'"
				},
				{
					"command": "forgeMarkdown.speEngineer",
					"when": "activeCustomEditorId == 'forge.conversationalMarkdown'"
				},
				{
					"command": "forgeMarkdown.revealNextOpenThread",
					"when": "activeCustomEditorId == 'forge.conversationalMarkdown'"
				}
			]
		}
	},
	"scripts": {
		"compile": "npm run build-webview && gulp compile-extension:forge-conversational-markdown",
		"watch": "gulp watch-extension:forge-conversational-markdown",
		"build-webview": "node ./esbuild.webview.mts"
	},
	"dependencies": {
		"markdown-it": "^12.3.2",
		"preact": "^10.28.0"
	},
	"devDependencies": {
		"@types/markdown-it": "^14.1.2",
		"@types/node": "22.x",
		"@types/vscode-webview": "^1.57.0"
	}
}
