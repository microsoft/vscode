{
	"compilerOptions": {
		"target": "ES2024",
		"module": "commonjs",
		"lib": ["ES2024"],
		"outDir": "./out",
		"rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"sourceMap": true,
		"typeRoots": ["./node_modules/@types"]
	},
	"include": ["src/**/*"]
}
