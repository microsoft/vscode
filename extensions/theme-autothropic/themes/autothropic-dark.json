  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6b6b63", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#a8d4a0" }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": { "foreground": "#d97757" }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": { "foreground": "#e0896a" }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#e8e5de" }
    },
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#e8e5de", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#c49ded" }
    },
    {
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#4cc9f0" }
    },
    {
      "scope": ["keyword.control"],
      "settings": { "foreground": "#c49ded" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#6cb6ff" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": { "foreground": "#d4a04a" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#f28482" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#D4A574", "fontStyle": "italic" }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": { "foreground": "#57ab5a" }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#7a7870" }
    },
    {
      "scope": ["meta.tag"],
      "settings": { "foreground": "#e8e5de" }
    },
    {
      "scope": ["support.constant"],
      "settings": { "foreground": "#4cc9f0" }
    },
    {
      "scope": ["entity.name.module", "variable.other.readwrite.alias"],
      "settings": { "foreground": "#d4a04a" }
    },
    {
      "scope": ["markup.heading"],
      "settings": { "foreground": "#d97757", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#a8d4a0" }
    },
    {
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#e5534b" }
    },
    {
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#57ab5a" }
    },
    {
      "scope": ["markup.changed"],
      "settings": { "foreground": "#539bf5" }
    },
    {
      "scope": ["meta.diff.header"],
      "settings": { "foreground": "#d97757" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#6cb6ff",
    "function.declaration": "#6cb6ff",
    "method": "#6cb6ff",
    "method.declaration": "#6cb6ff",
    "variable.readonly": "#4cc9f0",
    "property": "#e8e5de",
    "property.declaration": "#e8e5de",
    "parameter": { "foreground": "#e8e5de", "italic": true },
    "type": "#d4a04a",
    "class": "#d4a04a",
    "interface": "#d4a04a",
    "enum": "#d4a04a",
    "enumMember": "#4cc9f0",
    "namespace": "#d4a04a",
    "typeParameter": "#d4a04a"
  }
}