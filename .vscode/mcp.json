{
	"servers": {
		"microsoft/markitdown": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"markitdown-mcp@0.0.1a4"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		"vscode-automation-mcp": {
			"type": "stdio",
			"command": "npm",
			"args": [
				"run",
				"start-stdio"
			],
			"cwd": "${workspaceFolder}/test/mcp"
		},
		"component-explorer": {
			"type": "stdio",
			"command": "npm",
			"args": [
				"exec",
				"--no",
				"--",
				"component-explorer",
				"mcp",
				"-p",
				"./test/componentFixtures/component-explorer.json",
				"--use-daemon",
				"-vv"
			]
		}
	},
	"inputs": []
}