{
	"compilerOptions": {
		"target": "ES2022",
		"module": "commonjs",
		"moduleResolution": "node",
		"lib": ["ES2022"],
		"jsx": "react",
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declaration": false,
		"sourceMap": true,
		"forceConsistentCasingInFileNames": true,
		"baseUrl": ".",
		"paths": {
			"son-of-anton-core": ["../son-of-anton-core/dist/index.d.ts"],
			"son-of-anton-core/dist/*": ["../son-of-anton-core/dist/*"],
			"son-of-anton-core/*": ["../son-of-anton-core/dist/*.d.ts"]
		},
		"types": ["node", "react"],
		"typeRoots": [
			"./node_modules/@types",
			"../node_modules/@types"
		]
	},
	"include": ["src/**/*"],
	"exclude": ["dist", "node_modules"]
}
