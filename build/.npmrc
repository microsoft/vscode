disturl="https://nodejs.org/dist"
runtime="node"
target="22.22.1"
build_from_source="true"
force_process_config="true"
timeout=180000
min-release-age="1"

# pnpm settings (migrated from npm). build/ is installed as a standalone,
# Node-runtime project (separate from the Electron-runtime workspace) so native
# modules such as tree-sitter are built against Node headers.
node-linker=hoisted
strict-peer-dependencies=false
auto-install-peers=false
