disturl="https://electronjs.org/headers"
target="42.3.0"
ms_build_id="14159160"
runtime="electron"
ignore-scripts=false
build_from_source="true"
timeout=180000

# pnpm settings (migrated from npm)
# The codebase mixes two layout assumptions that a single linker mode cannot
# satisfy on its own:
#  1. Build/packaging tooling (build/lib/dependencies.ts, gulp
#     copy-from-node_modules, ASAR) expects a flat tree at the repo root.
#  2. Built-in extension builds reference their dependencies through their own
#     per-directory node_modules, e.g. `extensions/node_modules/typescript/lib`
#     and `extensions/copilot/node_modules/@github/copilot`. The npm setup
#     created one node_modules per directory (build/npm/dirs.ts), so these
#     paths existed.
# `node-linker=isolated` recreates the per-directory node_modules (as symlinks
# into the store) that those hardcoded paths rely on, while
# `shamefully-hoist=true` additionally mirrors every dependency into the root
# node_modules to preserve the flat tree the packaging tooling expects.
node-linker=isolated
shamefully-hoist=true
# Equivalent of npm's legacy-peer-deps=true: do not fail on peer mismatches.
strict-peer-dependencies=false
auto-install-peers=false
