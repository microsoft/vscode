disturl="https://electronjs.org/headers"
target="42.3.0"
ms_build_id="14159160"
runtime="electron"
ignore-scripts=false
build_from_source="true"
timeout=180000

# pnpm settings (migrated from npm)
# A hoisted node_modules layout is required: the build/packaging tooling
# (build/lib/dependencies.ts, gulp copy-from-node_modules, ASAR) assumes a flat
# tree rather than pnpm's default symlinked store.
node-linker=hoisted
# Equivalent of npm's legacy-peer-deps=true: do not fail on peer mismatches.
strict-peer-dependencies=false
auto-install-peers=false
